# ── Dependencies ──────────────────────────────────────────────
node_modules/

.pnpm-store/

# ── Build output ──────────────────────────────────────────────
dist/
dist-test/
coverage/
*.tsbuildinfo
*.tgz

# ── api-extractor working dir (snapshot is in etc/) ───────────
packages/*/temp/

# ── Security: secrets must never be committed ────────────────
.env
.env.*
*.pem
*.key
*.p12
*.pfx
.npmrc
*.pub

# ── Logs (may leak paths, tokens, stack traces) ───────────────
*.log
npm-debug.log*
pnpm-debug.log*

# ── Editor / OS noise ─────────────────────────────────────────
.DS_Store
.vscode/
.idea/
