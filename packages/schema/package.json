{
  "name": "@databehave/schema",
  "version": "0.1.2",
  "description": "Schemas for how data behaves, not just its shape.",
  "type": "module",
  "author": "ochairo",
  "license": "MIT",
  "homepage": "https://github.com/ochairo/databehave/tree/main/packages/schema#readme",
  "readme": "README.md",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ochairo/databehave.git",
    "directory": "packages/schema"
  },
  "bugs": {
    "url": "https://github.com/ochairo/databehave/issues"
  },
  "keywords": [
    "schema",
    "data-schema",
    "data-behavior",
    "mock-data",
    "fixture-generator",
    "deterministic",
    "seeded",
    "validation",
    "typescript",
    "testing"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./internal": {
      "types": "./dist/internal.d.ts",
      "import": "./dist/internal.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:test": "tsc -p tsconfig.test.json",
    "typecheck": "tsc --noEmit",
    "test": "find dist-test/test -name '*.test.js' -print0 | xargs -0 node --test",
    "test:watch": "tsc -p tsconfig.test.json --watch & find dist-test/test -name '*.test.js' -print0 | xargs -0 node --test --watch",
    "clean": "rm -rf dist dist-test",
    "pretest": "pnpm build:test"
  },
  "dependencies": {},
  "peerDependencies": {},
  "devDependencies": {
    "typescript": "6.0.3",
    "@types/node": "25.9.1"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
