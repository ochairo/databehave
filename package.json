{
  "name": "databehave",
  "version": "0.3.0",
  "description": "Schemas for how data behaves, not just its shape.",
  "type": "module",
  "author": "ochairo",
  "license": "MIT",
  "homepage": "https://github.com/ochairo/databehave#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ochairo/databehave.git"
  },
  "bugs": {
    "url": "https://github.com/ochairo/databehave/issues"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./internal": {
      "types": "./dist/internal.d.ts",
      "import": "./dist/internal.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18.17"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:test": "tsc -p tsconfig.test.json",
    "pretest": "pnpm build:test",
    "test": "find dist-test/test -name '*.test.js' -print0 | xargs -0 node --test",
    "test:watch": "tsc -p tsconfig.test.json --watch & find dist-test/test -name '*.test.js' -print0 | xargs -0 node --test --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist dist-test"
  },
  "dependencies": {},
  "peerDependencies": {},
  "devDependencies": {
    "typescript": "5.4.5",
    "@types/node": "20.14.0"
  },
  "keywords": [
    "schema",
    "data-schema",
    "mock",
    "mock-data",
    "fixture",
    "generator",
    "validator",
    "deterministic",
    "seeded",
    "zero-dependency",
    "typescript"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "packageManager": "pnpm@10.33.4+sha512.1c67b3b359b2d408119ba1ed289f34b8fc3c6873412bec6fd264fbdc82489e510fcbecb9ce9d22dae7f3b76269d8441046014bdca53b9979cd7a561ad631b800"
}
